  "keyFeatures": [
    "Generator-based monadic syntax for readable parser composition",
    "Full TypeScript type inference from input to output",
    "Rich error messages with position tracking and typo suggestions",
    "Commit/backtracking control for precise error reporting",
    "Performance-optimized fast paths for common operations",
    "Zero runtime dependencies"
  ],
  "publicApiSurface": [
    "Parser<T> - Core parser class with monadic operations",
    "parser() - Create parsers using generator syntax",
    "char() - Match single characters",
    "string() - Match exact strings",
    "regex() - Match regular expressions",
    "digit, letter, whitespace - Common character parsers",
    "many(), many1() - Zero or more, one or more repetitions",
    "or() - Try alternative parsers",
    "optional() - Zero or one occurrences",
    "sepBy(), sepBy1() - Parse separated lists",
    "between() - Parse delimited content",
    "lookahead() - Look ahead without consuming input",
    "notFollowedBy() - Negative lookahead",
    "commit() - Prevent backtracking for better errors",
    "manyChar(), manyDigit() - Optimized fast-path parsers",
    "Either<T, E> - Result type for success/failure",
    "ParserState - Parser state management",
    "ParseError, ParseErrorBundle - Error types",
    "formatError() - Format errors with source snippets"
  ]
}
